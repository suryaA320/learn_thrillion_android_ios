# Leave EXPO_PUBLIC_API_ORIGIN unset for day-to-day work.
# Local Metro/Expo Go → auto http://<your-PC-LAN-IP>:8000
# EAS preview/production → https://staging.learnthrillion.com (eas.json)

# Optional override only (rare):
# EXPO_PUBLIC_API_ORIGIN=http://10.0.2.2:8000

EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id
