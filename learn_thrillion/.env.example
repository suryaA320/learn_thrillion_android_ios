# Local dev — LAN IP or localhost (only works on same Wi‑Fi / emulator)
# EXPO_PUBLIC_API_ORIGIN=http://192.168.1.3:8000
# EXPO_PUBLIC_API_ORIGIN=http://127.0.0.1:8000

# Must match learn_thrillion_ui deployed API (REACT_APP_API_BASE_URL)
# Used by EAS preview/production builds — see eas.json
EXPO_PUBLIC_API_ORIGIN=https://staging.learnthrillion.com

# Set after running `npx eas init` (needed for push notifications)
EXPO_PUBLIC_EAS_PROJECT_ID=c1ea2bee-f5c5-4a79-8334-1baed7d35c9e
